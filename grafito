<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Grafito</title>
    <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.5.0/model-viewer.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        html, body {
            width: 100%;
            scroll-behavior: smooth;
        }

        /* ── Sección 1: Canvas GRAFITO ── */
        #hero {
            position: relative;
            width: 100%;
            height: 100vh;
            overflow: hidden;
        }

        canvas {
            display: block;
            width: 100%;
            height: 100%;
        }

        /* ── Botones sobre el canvas ── */
        #nav-buttons {
            position: absolute;
            bottom: 60px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 20px;
            z-index: 10;
        }

        .btn {
            padding: 12px 32px;
            font-family: 'Arial', sans-serif;
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            text-decoration: none;
            cursor: pointer;
            border: none;
            background: transparent;
            transition: all 0.3s ease;
        }

        .btn-outline {
            color: rgba(200, 200, 200, 0.85);
            border: 1px solid rgba(180, 180, 180, 0.35);
            background: rgba(10, 10, 10, 0.4);
            backdrop-filter: blur(4px);
        }

        .btn-outline:hover {
            color: #fff;
            border-color: rgba(220, 220, 220, 0.75);
            background: rgba(30, 30, 30, 0.6);
        }

        .btn-scroll {
            color: rgba(200, 200, 200, 0.7);
            border: 1px solid rgba(130, 130, 130, 0.25);
            background: transparent;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-scroll:hover {
            color: rgba(220, 220, 220, 0.95);
            border-color: rgba(180, 180, 180, 0.5);
        }

        .btn-scroll .arrow {
            display: inline-block;
            width: 14px;
            height: 14px;
            border-right: 2px solid currentColor;
            border-bottom: 2px solid currentColor;
            transform: rotate(45deg);
            margin-top: -4px;
        }

        /* ── Sección 2: Info ── */
        #info {
            width: 100%;
            min-height: 100vh;
            background: #f9f8f6;
            display: flex;
            align-items: center;
            padding: 80px 8%;
        }

        .info-inner {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 56px;
            max-width: 1100px;
            width: 100%;
            margin: 0 auto;
            align-items: center;
        }

        /* Columna izquierda: modelo 3D */
        .info-left {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 460px;
        }

        model-viewer {
            width: 100%;
            height: 460px;
            background: transparent;
            --poster-color: transparent;
        }

        .hero-heading {
            font-family: Georgia, 'Times New Roman', serif;
            font-size: clamp(36px, 4.5vw, 62px);
            font-weight: 700;
            color: #1a3a8f;
            line-height: 1.1;
            margin-bottom: 24px;
        }

        .hero-heading em {
            font-style: italic;
        }

        /* Columna derecha */
        .info-right {
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .info-desc {
            font-family: 'Arial', sans-serif;
            font-size: 15px;
            font-weight: 600;
            color: #1a1a1a;
            line-height: 1.6;
            margin-bottom: 28px;
        }

        .info-divider {
            width: 100%;
            height: 2px;
            background: #1a3a8f;
            margin-bottom: 36px;
        }

        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 28px 40px;
        }

        .info-card-label {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 6px;
        }

        .info-card-label::before {
            content: '';
            display: inline-block;
            width: 36px;
            height: 3px;
            background: #1a3a8f;
            flex-shrink: 0;
        }

        .info-card-label span {
            font-family: 'Arial Black', 'Arial', sans-serif;
            font-size: 15px;
            font-weight: 900;
            color: #1a1a1a;
            letter-spacing: 0.3px;
        }

        .info-card-value {
            padding-left: 48px;
            font-family: 'Arial', sans-serif;
            font-size: 13px;
            font-weight: 700;
            color: #666;
            letter-spacing: 0.3px;
        }

        footer {
            padding: 48px 8%;
            display: flex;
            justify-content: center;
            background: #f9f8f6;
            border-top: 1px solid rgba(26, 58, 143, 0.15);
        }

        .footer-home-btn {
            display: inline-flex;
            align-items: center;
             gap: 10px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: #555;
            padding: 14px 36px;
            border: 1px solid rgba(26, 58, 143, 0.3);
            transition: all 0.25s ease;
        }

        .footer-home-btn:hover {
            color: #fff;
            background: #1a3a8f;
            border-color: #1a3a8f;
        }

        .footer-home-btn:hover .footer-arrow {
            border-color: #fff;
        }

        .footer-arrow {
            display: inline-block;
            width: 10px;
            height: 10px;
            border-left: 2px solid #555;
            border-bottom: 2px solid #555;
            transform: rotate(45deg);
            transition: border-color 0.25s ease;
        }

        /* ── Tablet (≤ 900px) ── */
        @media (max-width: 900px) {
            #nav-buttons { gap: 12px; }

            .btn {
                padding: 10px 20px;
                font-size: 11px;
                letter-spacing: 1.8px;
            }

            .info-inner {
                grid-template-columns: 1fr;
                gap: 32px;
            }

            model-viewer { height: 340px; }
            .info-left { min-height: 340px; }

            #info {
                padding: 64px 8%;
                min-height: auto;
            }
        }

        /* ── Mobile (≤ 600px) ── */
        @media (max-width: 600px) {
            #nav-buttons {
                flex-direction: column;
                align-items: stretch;
                width: 75%;
                gap: 10px;
                bottom: 36px;
            }

            .btn {
                width: 100%;
                text-align: center;
                justify-content: center;
                padding: 13px 16px;
                font-size: 11px;
                letter-spacing: 1.5px;
            }

            .btn-scroll { justify-content: center; }

            #info { padding: 48px 6%; }

            model-viewer { height: 260px; }
            .info-left { min-height: 260px; }

            .info-grid {
                grid-template-columns: 1fr;
                gap: 18px;
            }

            footer { padding: 32px 6%; }

            .footer-home-btn {
                padding: 12px 22px;
                font-size: 11px;
                letter-spacing: 2px;
            }
        }
    </style>
</head>
<body>

    <!-- ── Sección 1: GRAFITO canvas ── -->
    <section id="hero">
        <canvas id="c"></canvas>

        <nav id="nav-buttons">
            <a href="proyectos.html" class="btn btn-outline">Proyectos</a>
            <button class="btn btn-scroll" onclick="document.getElementById('info').scrollIntoView({behavior:'smooth'})">
                Nosotros <span class="arrow"></span>
            </button>
            <a href="contactos.html" class="btn btn-outline">Contacto</a>
        </nav>
    </section>

    <!-- ── Sección 2: Info ── -->
    <section id="info">
        <div class="info-inner">

            <!-- Columna izquierda: modelo 3D -->
            <div class="info-left">
                <model-viewer
                    id="modelo3d"
                    src="modelo1.glb"
                    camera-controls
                    disable-zoom
                    auto-rotate
                    shadow-intensity="1"
                    exposure="1.1"
                    rotation-per-second="25deg"
                ></model-viewer>
            </div>

            <!-- Columna derecha: texto e info -->
            <div class="info-right">
                <h1 class="hero-heading">Ideas <em>que</em><br>dejan marca.</h1>
                <p class="info-desc">
                    Somos un estudio independiente que transforma marcas, editoriales
                    y productos a través del diseño. Cada proyecto, un trazo único.
                </p>
                <div class="info-divider"></div>
                <div class="info-grid">
                    <div class="info-card">
                        <div class="info-card-label"><span>Base</span></div>
                        <div class="info-card-value">Soriano, Uy</div>
                    </div>
                    <div class="info-card">
                        <div class="info-card-label"><span>Disponibilidad</span></div>
                        <div class="info-card-value">24/7</div>
                    </div>
                    <div class="info-card">
                        <div class="info-card-label"><span>Servicios</span></div>
                        <div class="info-card-value">Branding – Editorial – Web</div>
                    </div>
                    <div class="info-card">
                        <div class="info-card-label"><span>Proyectos</span></div>
                        <div class="info-card-value">+8 Entregados</div>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <footer>
        <a href="#hero" class="footer-home-btn" onclick="window.scrollTo({top:0,behavior:'smooth'});return false;">
            <span class="footer-arrow"></span> Volver arriba
        </a>
    </footer>

    <script>
    const c = document.getElementById('c');
    const ctx = c.getContext('2d');

    const off = document.createElement('canvas');
    const octx = off.getContext('2d');

    let W, H;

    function setup() {
        W = c.width = off.width = window.innerWidth;
        H = c.height = off.height = window.innerHeight;
        drawBase();
        requestAnimationFrame(loop);
    }

    function drawBase() {
        octx.fillStyle = '#181818';
        octx.fillRect(0, 0, W, H);

        const img = octx.getImageData(0, 0, W, H);
        const d = img.data;
        for (let i = 0; i < d.length; i += 4) {
            const g = Math.floor(Math.random() * 22);
            d[i] = d[i+1] = d[i+2] = g;
            d[i+3] = 255;
        }
        octx.putImageData(img, 0, 0);

        octx.save();
        octx.lineCap = 'round';
        for (let n = 0; n < 500; n++) {
            const x = Math.random() * W;
            const y = Math.random() * H;
            const len = Math.random() * 55 + 5;
            const a = Math.PI * 0.23 + (Math.random() - 0.5) * 0.6;
            octx.beginPath();
            octx.moveTo(x, y);
            octx.lineTo(x + Math.cos(a) * len, y + Math.sin(a) * len);
            const v = 12 + Math.floor(Math.random() * 22);
            octx.strokeStyle = `rgba(${v},${v},${v},${0.04 + Math.random() * 0.1})`;
            octx.lineWidth = 0.2 + Math.random() * 0.9;
            octx.stroke();
        }
        octx.restore();

        const vig = octx.createRadialGradient(W/2, H/2, H * 0.15, W/2, H/2, H * 0.78);
        vig.addColorStop(0, 'rgba(0,0,0,0)');
        vig.addColorStop(1, 'rgba(0,0,0,0.6)');
        octx.fillStyle = vig;
        octx.fillRect(0, 0, W, H);

        drawTitle();

    }

    function drawTitle() {
        const cx = W / 2;
        const cy = H * 0.65;
        const fs = Math.min(W * 0.15, 148);

        octx.save();
        octx.font = `900 ${fs}px 'Arial Black', 'Impact', Arial, sans-serif`;
        octx.textAlign = 'center';
        octx.textBaseline = 'middle';
        octx.shadowColor = 'rgba(0,0,0,0.95)';
        octx.shadowBlur = 35;
        octx.shadowOffsetX = 5;
        octx.shadowOffsetY = 7;

        const g = octx.createLinearGradient(cx - fs * 3, cy - fs * 0.55, cx + fs * 3, cy + fs * 0.55);
        g.addColorStop(0,    '#282828');
        g.addColorStop(0.12, '#585858');
        g.addColorStop(0.28, '#a0a0a0');
        g.addColorStop(0.42, '#d6d6d6');
        g.addColorStop(0.5,  '#ececec');
        g.addColorStop(0.58, '#b8b8b8');
        g.addColorStop(0.72, '#c4c4c4');
        g.addColorStop(0.86, '#5c5c5c');
        g.addColorStop(1,    '#242424');

        octx.fillStyle = g;
        octx.fillText('GRAFITO', cx, cy);
        octx.restore();

        octx.save();
        octx.font = `900 ${fs}px 'Arial Black', 'Impact', Arial, sans-serif`;
        const tw = octx.measureText('GRAFITO').width;
        octx.restore();

        const rx = Math.floor(cx - tw / 2 - 8);
        const ry = Math.floor(cy - fs * 0.7);
        const rw = Math.ceil(tw + 16);
        const rh = Math.ceil(fs * 1.4);

        if (rx >= 0 && ry >= 0 && rx + rw <= W && ry + rh <= H) {
            const region = octx.getImageData(rx, ry, rw, rh);
            const rd = region.data;
            for (let i = 0; i < rd.length; i += 4) {
                if (rd[i] > 28) {
                    const shift = (Math.random() - 0.5) * 38;
                    const val = Math.max(0, Math.min(255, rd[i] + shift));
                    rd[i] = rd[i+1] = rd[i+2] = val;
                }
            }
            octx.putImageData(region, rx, ry);
        }

        octx.save();
        octx.font = `900 ${fs}px 'Arial Black', 'Impact', Arial, sans-serif`;
        octx.textAlign = 'center';
        octx.textBaseline = 'middle';
        octx.strokeStyle = 'rgba(80,80,80,0.35)';
        octx.lineWidth = 1.5;
        octx.shadowBlur = 0;
        octx.strokeText('GRAFITO', cx, cy);
        octx.restore();
    }

    function loop() {
        ctx.drawImage(off, 0, 0);
        requestAnimationFrame(loop);
    }

    window.addEventListener('resize', setup);
    setup();

    // Modelo 3D: aparece en el hero (lado izquierdo) y se desliza al info-left al hacer scroll
    const modelEl    = document.getElementById('modelo3d');
    const infoLeftEl = document.querySelector('.info-left');
    let curX = null, curY = null, curW = null, curH = null;

    function getHeroDims(vw, vh) {
        if (vw <= 600) return { x: vw * 0.20, y: vh * 0.04, w: vw * 0.60, h: vh * 0.44 };
        if (vw <= 900) return { x: vw * 0.25, y: vh * 0.03, w: vw * 0.50, h: vh * 0.50 };
        return                { x: vw * 0.35, y: vh * 0.03, w: vw * 0.30, h: vh * 0.55 };
    }

    function updateModelPos() {
        const scrollY = window.scrollY;
        const vw = window.innerWidth;
        const vh = window.innerHeight;

        const heroH    = document.getElementById('hero').offsetHeight;
        const progress = Math.max(0, Math.min(1, scrollY / heroH));
        const eased    = progress * progress * (3 - 2 * progress);

        const { x: hx, y: hy, w: hw, h: hh } = getHeroDims(vw, vh);
        const r  = infoLeftEl.getBoundingClientRect();
        const iw = r.width  || vw * 0.45;
        const ih = r.height || 460;

        const tx = hx + (r.left - hx) * eased;
        const ty = hy + (r.top  - hy) * eased;
        const tw = hw + (iw - hw) * eased;
        const th = hh + (ih - hh) * eased;

        // Inicializar sin lerp en la primera llamada
        if (curX === null) { curX = tx; curY = ty; curW = tw; curH = th; }

        // Lerp suave: k pequeño = transición más lenta y fluida
        const k = 0.06;
        curX += (tx - curX) * k;
        curY += (ty - curY) * k;
        curW += (tw - curW) * k;
        curH += (th - curH) * k;

        modelEl.style.cssText = `
            position: fixed;
            left:   ${curX}px;
            top:    ${curY}px;
            width:  ${curW}px;
            height: ${curH}px;
            z-index: 5;
            opacity: 1;
            transform: none;
            pointer-events: ${progress >= 1 ? 'auto' : 'none'};
            transition: none;
            background: transparent;
        `;
    }

    (function rafLoop() { updateModelPos(); requestAnimationFrame(rafLoop); })();
    </script>

</body>
</html>
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Proyectos — Grafito</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: #080808;
            font-family: 'Arial', sans-serif;
            color: #fff;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* ── Header ── */
        header {
            padding: 28px 8%;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: relative;
            z-index: 10;
        }

        .logo {
            font-family: 'Arial Black', Arial, sans-serif;
            font-size: 20px;
            font-weight: 900;
            letter-spacing: 4px;
            color: #fff;
            text-decoration: none;
        }

        .back-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.5);
            transition: color 0.2s;
        }

        .back-btn:hover { color: #fff; }

        .back-btn .arrow {
            display: inline-block;
            width: 9px;
            height: 9px;
            border-left: 1.5px solid currentColor;
            border-bottom: 1.5px solid currentColor;
            transform: rotate(45deg);
        }

        /* ── Título ── */
        .hero-text {
            text-align: center;
            padding: 48px 8% 56px;
            opacity: 0;
            animation: fadeUp 0.7s ease 0.1s forwards;
        }

        .hero-text h1 {
            font-family: Georgia, 'Times New Roman', serif;
            font-size: clamp(32px, 5vw, 62px);
            font-weight: 700;
            color: #fff;
            line-height: 1.15;
        }

        .hero-text h1 em { font-style: italic; }

        .hero-text p {
            margin-top: 14px;
            font-size: 14px;
            color: rgba(255,255,255,0.38);
            letter-spacing: 0.5px;
        }

        /* ── Carrusel ── */
        .carousel-wrap {
            position: relative;
            width: 100%;
            padding-bottom: 72px;
        }

        .carousel-scene {
            perspective: 1100px;
            position: relative;
            width: 100%;
            height: 480px;
        }

        /* Carta base */
        .c-card {
            position: absolute;
            left: 50%;
            top: 50%;
            width: 248px;
            height: 374px;
            border-radius: 18px;
            overflow: hidden;
            transition:
                transform 0.68s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                opacity   0.68s ease,
                box-shadow 0.68s ease;
            user-select: none;
        }

        /* Posiciones */
        .pos-far-left {
            transform: translate(calc(-50% - 420px), -50%) rotateY(44deg) scale(0.62);
            opacity: 0.32;
            z-index: 1;
            cursor: pointer;
        }
        .pos-left {
            transform: translate(calc(-50% - 228px), -50%) rotateY(30deg) scale(0.81);
            opacity: 0.68;
            z-index: 2;
            cursor: pointer;
        }
        .pos-center {
            transform: translate(-50%, -50%) rotateY(0deg) scale(1);
            opacity: 1;
            z-index: 5;
            box-shadow: 0 32px 90px rgba(0,0,0,0.75), 0 0 0 1px rgba(255,255,255,0.07);
            cursor: default;
        }
        .pos-right {
            transform: translate(calc(-50% + 228px), -50%) rotateY(-30deg) scale(0.81);
            opacity: 0.68;
            z-index: 2;
            cursor: pointer;
        }
        .pos-far-right {
            transform: translate(calc(-50% + 420px), -50%) rotateY(-44deg) scale(0.62);
            opacity: 0.32;
            z-index: 1;
            cursor: pointer;
        }
        .pos-hidden {
            transform: translate(-50%, -50%) scale(0.15);
            opacity: 0;
            z-index: 0;
            pointer-events: none;
        }

        /* Imagen de la carta */
        .c-card-img {
            width: 100%;
            height: 100%;
            position: relative;
        }

        .c-card-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        /* Gradientes de placeholder */
        .c-card:nth-child(1) .c-card-img { background: linear-gradient(160deg, #1a0000 0%, #7f1d1d 45%, #dc2626 100%); }
        .c-card:nth-child(2) .c-card-img { background: linear-gradient(160deg, #0c0800 0%, #92400e 45%, #d97706 100%); }
        .c-card:nth-child(3) .c-card-img { background: linear-gradient(160deg, #111 0%, #374151 45%, #9ca3af 100%); }
        .c-card:nth-child(4) .c-card-img { background: linear-gradient(160deg, #000d1a 0%, #0e4e7c 45%, #38bdf8 100%); }
        .c-card:nth-child(5) .c-card-img { background: linear-gradient(160deg, #0d0014 0%, #5b21b6 45%, #a78bfa 100%); }
        .c-card:nth-child(6) .c-card-img { background: linear-gradient(160deg, #0a0500 0%, #9a3412 45%, #fb923c 100%); }

        /* Overlay inferior */
        .c-card-overlay {
            position: absolute;
            bottom: 0; left: 0; right: 0;
            padding: 48px 20px 22px;
            background: linear-gradient(to top, rgba(0,0,0,0.88) 0%, transparent 100%);
        }

        .c-card-tag {
            display: block;
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.5);
            margin-bottom: 6px;
        }

        .c-card-title {
            font-family: Georgia, serif;
            font-size: 16px;
            font-weight: 700;
            color: #fff;
            line-height: 1.3;
        }

        /* ── Navegación ── */
        .nav-btn {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.12);
            color: rgba(255,255,255,0.7);
            width: 44px;
            height: 44px;
            border-radius: 50%;
            font-size: 18px;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 10;
        }

        .nav-btn:hover {
            background: rgba(255,255,255,0.15);
            color: #fff;
        }

        .nav-prev { left: 4%; }
        .nav-next { right: 4%; }

        /* ── Dots ── */
        .carousel-dots {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin-top: 36px;
        }

        .dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: rgba(255,255,255,0.22);
            border: none;
            cursor: pointer;
            transition: all 0.3s ease;
            padding: 0;
        }

        .dot.active {
            background: #fff;
            width: 22px;
            border-radius: 3px;
        }

        /* ── Animaciones de entrada ── */
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ── Footer ── */
        footer {
            padding: 40px 8%;
            display: flex;
            justify-content: center;
            border-top: 1px solid rgba(255,255,255,0.07);
        }

        .footer-home-btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.45);
            padding: 13px 32px;
            border: 1px solid rgba(255,255,255,0.12);
            transition: all 0.25s ease;
        }

        .footer-home-btn:hover {
            color: #fff;
            border-color: rgba(255,255,255,0.4);
        }

        .footer-arrow {
            display: inline-block;
            width: 9px;
            height: 9px;
            border-left: 1.5px solid currentColor;
            border-bottom: 1.5px solid currentColor;
            transform: rotate(45deg);
        }

        /* ── Tablet ── */
        @media (max-width: 900px) {
            .carousel-scene { height: 420px; }
            .c-card { width: 210px; height: 316px; }
            .pos-far-left  { transform: translate(calc(-50% - 340px), -50%) rotateY(44deg) scale(0.6);  opacity: 0.25; }
            .pos-left      { transform: translate(calc(-50% - 190px), -50%) rotateY(30deg) scale(0.78); opacity: 0.6;  }
            .pos-right     { transform: translate(calc(-50% + 190px), -50%) rotateY(-30deg) scale(0.78); opacity: 0.6; }
            .pos-far-right { transform: translate(calc(-50% + 340px), -50%) rotateY(-44deg) scale(0.6); opacity: 0.25; }
        }

        /* ── Mobile ── */
        @media (max-width: 600px) {
            .hero-text { padding: 36px 6% 44px; }
            .carousel-scene { height: 380px; }
            .c-card { width: 200px; height: 300px; border-radius: 14px; }
            .pos-far-left  { opacity: 0; pointer-events: none; transform: translate(-50%, -50%) scale(0.1); }
            .pos-far-right { opacity: 0; pointer-events: none; transform: translate(-50%, -50%) scale(0.1); }
            .pos-left      { transform: translate(calc(-50% - 150px), -50%) rotateY(25deg) scale(0.75); opacity: 0.5; }
            .pos-right     { transform: translate(calc(-50% + 150px), -50%) rotateY(-25deg) scale(0.75); opacity: 0.5; }
            .nav-prev { left: 1%; }
            .nav-next { right: 1%; }
        }
    </style>
</head>
<body>

    <header>
        <a href="Index.html" class="logo">GRAFITO</a>
        <a href="Index.html" class="back-btn">
            <span class="arrow"></span> Volver
        </a>
    </header>

    <div class="hero-text">
        <h1>Trabajos <em>seleccionados.</em></h1>
        <p>Cada proyecto, un trazo único.</p>
    </div>

    <div class="carousel-wrap">
        <div class="carousel-scene">

            <div class="c-card">
                <div class="c-card-img"></div>
                <div class="c-card-overlay">
                    <span class="c-card-tag">Branding</span>
                    <h3 class="c-card-title">Proyecto 1</h3>
                </div>
            </div>

            <div class="c-card">
                <div class="c-card-img"></div>
                <div class="c-card-overlay">
                    <span class="c-card-tag">Editorial</span>
                    <h3 class="c-card-title">Proyecto 2</h3>
                </div>
            </div>

            <div class="c-card">
                <div class="c-card-img"></div>
                <div class="c-card-overlay">
                    <span class="c-card-tag">Web</span>
                    <h3 class="c-card-title">Proyecto 3</h3>
                </div>
            </div>

            <div class="c-card">
                <div class="c-card-img"></div>
                <div class="c-card-overlay">
                    <span class="c-card-tag">Branding</span>
                    <h3 class="c-card-title">Proyecto 4</h3>
                </div>
            </div>

            <div class="c-card">
                <div class="c-card-img"></div>
                <div class="c-card-overlay">
                    <span class="c-card-tag">Editorial</span>
                    <h3 class="c-card-title">Proyecto 5</h3>
                </div>
            </div>

            <div class="c-card">
                <div class="c-card-img"></div>
                <div class="c-card-overlay">
                    <span class="c-card-tag">Web</span>
                    <h3 class="c-card-title">Proyecto 6</h3>
                </div>
            </div>

        </div>

        <button class="nav-btn nav-prev" aria-label="Anterior">&#8249;</button>
        <button class="nav-btn nav-next" aria-label="Siguiente">&#8250;</button>

        <div class="carousel-dots"></div>
    </div>

    <footer>
        <a href="Index.html" class="footer-home-btn">
            <span class="footer-arrow"></span> Volver al inicio
        </a>
    </footer>

    <script>
    const cards   = Array.from(document.querySelectorAll('.c-card'));
    const dotsWrap = document.querySelector('.carousel-dots');
    const N = cards.length;
    let active = 0;
    let animating = false;

    // Crear dots
    cards.forEach((_, i) => {
        const d = document.createElement('button');
        d.className = 'dot' + (i === 0 ? ' active' : '');
        d.addEventListener('click', () => goTo(i));
        dotsWrap.appendChild(d);
    });

    const dots = Array.from(dotsWrap.querySelectorAll('.dot'));

    function posKey(diff) {
        if (diff === 0)                              return 'pos-center';
        if (diff === 1  || diff === -(N - 1))       return 'pos-right';
        if (diff === -1 || diff ===  (N - 1))       return 'pos-left';
        if (diff === 2  || diff === -(N - 2))       return 'pos-far-right';
        if (diff === -2 || diff ===  (N - 2))       return 'pos-far-left';
        return 'pos-hidden';
    }

    function update() {
        cards.forEach((card, i) => {
            let diff = i - active;
            if (diff >  N / 2) diff -= N;
            if (diff < -N / 2) diff += N;

            card.className = 'c-card ' + posKey(diff);
        });

        dots.forEach((d, i) => d.classList.toggle('active', i === active));
    }

    function goTo(index) {
        if (animating || index === active) return;
        animating = true;
        active = ((index % N) + N) % N;
        update();
        setTimeout(() => { animating = false; }, 680);
    }

    function next() { goTo(active + 1); }
    function prev() { goTo(active - 1); }

    // Clicks en cartas laterales
    cards.forEach((card, i) => {
        card.addEventListener('click', () => {
            const cls = card.className;
            if (cls.includes('pos-left') || cls.includes('pos-far-left'))  prev();
            if (cls.includes('pos-right') || cls.includes('pos-far-right')) next();
        });
    });

    // Botones
    document.querySelector('.nav-prev').addEventListener('click', prev);
    document.querySelector('.nav-next').addEventListener('click', next);

    // Teclado
    document.addEventListener('keydown', e => {
        if (e.key === 'ArrowRight') next();
        if (e.key === 'ArrowLeft')  prev();
    });

    // Touch / swipe
    let touchX = 0;
    document.addEventListener('touchstart', e => { touchX = e.touches[0].clientX; }, { passive: true });
    document.addEventListener('touchend', e => {
        const dx = e.changedTouches[0].clientX - touchX;
        if (Math.abs(dx) > 48) dx < 0 ? next() : prev();
    });

    // Init
    update();
    </script>

